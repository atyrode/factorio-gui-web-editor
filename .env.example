# Recommended setup:
# scripts/setup-basic-auth-env.sh
# docker compose -f /home/alex/edge-proxy/compose.yaml restart caddy
#
# The script prompts for the password without echoing it, generates the Caddy
# bcrypt hash, and writes .env locally. Do not put the plaintext password in a
# shell command.
LABTORIO_BASIC_AUTH_USER=labtorio

# Use the exact Caddy bcrypt output. It should start like `$2a$`, `$2b$`, or
# `$2y$` and contain three `$` separators. Do not use a raw password, SHA-256
# digest, or base64 value. Keep the hash single-quoted so Docker Compose does
# not treat `$` as interpolation.
LABTORIO_BASIC_AUTH_HASH='<caddy-bcrypt-hash>'
