{
  "name": "factorio-gui-web-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "vite build && node scripts/copy-static-docs.mjs",
    "catalog:generate": "node scripts/generate-factorio-style-catalog.mjs",
    "check": "npm run build && node scripts/check-layout-tree.mjs && node scripts/check-hover-drop-geometry.mjs && node scripts/check-style-catalog.mjs && python3 scripts/check-app.py && npm run test:browser",
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "test:browser": "playwright test"
  },
  "dependencies": {
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "fflate": "^0.8.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.8.0",
    "vite": "^8.0.13"
  }
}
